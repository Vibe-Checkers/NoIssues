# Dockerfile for folly
# Generated by Planner Agent
# Repository: https://github.com/facebook/folly
# Analysis Date: 2025-12-10 12:00:11

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install build tools and common dependencies for Folly (CMake-based, Python available)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        ninja-build \
        python3 \
        python3-pip \
        python3-dev \
        zlib1g-dev \
        libbz2-dev \
        libdouble-conversion-dev \
        libevent-dev \
        libgflags-dev \
        libglog-dev \
        liblz4-dev \
        liblzma-dev \
        libssl-dev \
        libzstd-dev \
        libsnappy-dev \
        libboost-all-dev \
        pkg-config \
        git \
        ca-certificates \
        curl \
        tzdata \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy repository contents
COPY . /app/

# Build Folly using CMake
RUN mkdir -p build && cd build && \
    cmake -DCMAKE_BUILD_TYPE=Release .. && \
    cmake --build . -- -j$(nproc) && \
    cmake --build . --target install

# Optional: If the repository provides Python-based dependency tooling (e.g., getdeps.py), you can uncomment the line below
# RUN python3 ./build/fbcode_builder/getdeps.py --allow-system-packages build

# Default command (interactive shell)
CMD ["/bin/bash"]