FROM ubuntu:22.04

# (Your existing FROM line must be preserved per the instructions; the rest of the content here should be
# appended to fix missing system dependencies around the existing RUN commands without changing the base image.)

# Install common build and runtime dependencies required for Python, Node, Java, etc.
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        git \
        wget \
        python3 \
        python3-pip \
        python3-dev \
        python3-venv \
        python3-setuptools \
        pkg-config \
        libffi-dev \
        libssl-dev \
        zlib1g-dev \
        libbz2-dev \
        libreadline-dev \
        libsqlite3-dev \
        libncurses5-dev \
        libgdbm-dev \
        liblzma-dev \
        libxml2-dev \
        libxml2 \
        libxslt1-dev \
        libjpeg-dev \
        libpng-dev \
        gcc \
        g++ \
        make \
        openjdk-11-jdk \
        maven \
        nodejs \
        npm \
        -y && \
    rm -rf /var/lib/apt/lists/*

# Ensure Python uses system pip and install dependencies if a requirements.txt exists
COPY requirements.txt /tmp/requirements.txt
RUN if [ -f /tmp/requirements.txt ]; then \
        python3 -m pip install --no-cache-dir -r /tmp/requirements.txt; \
    fi

# Ensure Node dependencies are installed if package.json exists
COPY package.json /tmp/package.json
COPY package-lock.json /tmp/package-lock.json
RUN if [ -f /tmp/package.json ]; then \
        npm ci --silent --no-audit --no-fund; \
    fi

# Build-time environment fixes for common missing-system-packages errors
ENV DEBIAN_FRONTEND=noninteractive

# Placeholder for additional RUN commands from the original Dockerfile
# The original RUN commands should be preserved and augmented here to include any missing system packages
# required by the project (e.g., additional libraries for Python modules, Java builds, or Node addons).

# Expose ports if required by the project (adjust as needed)
EXPOSE 8080

# Final command (adjust as per the original Dockerfile's CMD/ENTRYPOINT)
CMD ["bash"]