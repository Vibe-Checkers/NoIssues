# Generated by Planner Agent
# Repository: https://github.com/google/guava
# Analysis Date: 2025-12-10 12:07:28

FROM maven:3.8.7-openjdk-11 AS builder
WORKDIR /workspace
# Copy the entire repository to leverage Maven's cache
COPY . .
# Build all modules, skipping tests for faster image creation
RUN mvn -B -DskipTests package

FROM openjdk:11-jre-slim
WORKDIR /app
# Copy built artifacts from the builder stage
COPY --from=builder /workspace/guava/guava/target /app/target
# Default command since Guava is a library and does not run as a standalone service
CMD ["bash"]