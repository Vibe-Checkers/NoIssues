# ─── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL_NANO=google/gemini-2.0-flash-001
OPENROUTER_MODEL_CHAT=anthropic/claude-sonnet-4

# ─── Rate Limiting ────────────────────────────────────────────────────────────
LLM_RPM=60
LLM_TPM=200000
RATE_LIMIT_HEADROOM=0.9

# ─── Docker ───────────────────────────────────────────────────────────────────
DOCKER_BUILD_TIMEOUT=600
DOCKER_BUILD_CONCURRENCY=2
DOCKER_SMOKE_TIMEOUT=30

# ─── Disk Space Monitor ───────────────────────────────────────────────────────
DISK_SPACE_THRESHOLD_GB=5

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///results.db
# DATABASE_URL=postgresql://user:password@localhost:5432/buildagent

# ─── Agent ────────────────────────────────────────────────────────────────────
MAX_ITERATIONS=3
MAX_STEPS_PER_ITERATION=15
SUMMARIZE_THRESHOLD=2000

# ─── Batch Runner ─────────────────────────────────────────────────────────────
WORKERS=4
