# ─── Azure OpenAI — nano model (agent steps, blueprints, tool reviews) ────────
AZURE_OPENAI_API_KEY=your-nano-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-nano-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NANO=gpt5-nano

# ─── Azure OpenAI — chat model (lesson extraction, analysis) ──────────────────
# If chat is on a different Azure resource, set these. Otherwise leave unset
# and they will fall back to the nano endpoint/key above.
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt5-chat
AZURE_OPENAI_ENDPOINT_CHAT=https://your-chat-resource.openai.azure.com/
AZURE_OPENAI_API_KEY_CHAT=your-chat-api-key-here

# ─── Rate Limiting ────────────────────────────────────────────────────────────
AZURE_OPENAI_RPM=250
AZURE_OPENAI_TPM=250000
RATE_LIMIT_HEADROOM=0.9

# ─── Docker ───────────────────────────────────────────────────────────────────
DOCKER_BUILD_TIMEOUT=600
DOCKER_BUILD_CONCURRENCY=2
DOCKER_SMOKE_TIMEOUT=30

# ─── Disk Space Monitor ───────────────────────────────────────────────────────
DISK_SPACE_THRESHOLD_GB=5

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///results.db
# DATABASE_URL=postgresql://user:password@localhost:5432/buildagent

# ─── Agent ────────────────────────────────────────────────────────────────────
MAX_ITERATIONS=3
MAX_STEPS_PER_ITERATION=15
SUMMARIZE_THRESHOLD=2000

# ─── Batch Runner ─────────────────────────────────────────────────────────────
WORKERS=4
