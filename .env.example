# ─── Azure OpenAI (gpt5-nano — used for agent steps, blueprints, reviews) ────
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NANO=gpt5-nano

# ─── Azure OpenAI (gpt5-chat — used for lesson extraction and analysis) ───────
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt5-chat

# ─── Rate Limiting ────────────────────────────────────────────────────────────
AZURE_OPENAI_RPM=60
AZURE_OPENAI_TPM=80000
RATE_LIMIT_HEADROOM=0.9

# ─── Docker ───────────────────────────────────────────────────────────────────
DOCKER_BUILD_TIMEOUT=600
DOCKER_BUILD_CONCURRENCY=2
DOCKER_SMOKE_TIMEOUT=30

# ─── Disk Space Monitor ───────────────────────────────────────────────────────
DISK_SPACE_THRESHOLD_GB=5

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default):
DATABASE_URL=sqlite:///results.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/buildagent

# ─── Agent ────────────────────────────────────────────────────────────────────
MAX_ITERATIONS=3
MAX_STEPS_PER_ITERATION=15
SUMMARIZE_THRESHOLD=2000

# ─── Batch Runner ─────────────────────────────────────────────────────────────
WORKERS=4
